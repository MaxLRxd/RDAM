        {
          "name": "webhook-pago (global/legacy)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Webhook global: formato PascalCase, busca por idOrdenPago en DB.",
                  "// NOTA: solo funciona si el idOrdenPago del mock coincide con el guardado",
                  "// en la solicitud. En el flujo real el mock lo envía automáticamente.",
                  "// Para tests manuales usar callback-pago-aprobado que busca por nroTramite.",
                  "",
                  "var hmacSecret = pm.environment.get('hmac_secret') || 'clave-secreta-campus-2026';",
                  "var nroTramite = pm.environment.get('nro_tramite');",
                  "",
                  "var body = JSON.stringify({",
                  "    Tipo: 'PAGO',",
                  "    TransaccionPlataformaId: '999999',",
                  "    TransaccionComercioId: nroTramite,",
                  "    Monto: '1500.00',",
                  "    EstadoId: '3',",
                  "    Estado: 'REALIZADA',",
                  "    FechaProcesamiento: new Date().toISOString()",
                  "});",
                  "",
                  "var hash = CryptoJS.HmacSHA256(body, hmacSecret);",
                  "var firma = CryptoJS.enc.Hex.stringify(hash);",
                  "",
                  "pm.environment.set('webhook_body', body);",
                  "pm.environment.set('hmac_firma_webhook', firma);",
                  "",
                  "console.log('Webhook body:', body);",
                  "console.log('HMAC firma:', firma);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "if (pm.response.code === 200) {",
                  "    console.log('Webhook procesado. Solicitud debería estar en PAGADO.');",
                  "} else if (pm.response.code === 404) {",
                  "    console.log('ERROR 404: No encontró solicitud por idOrdenPago.');",
                  "    console.log('El webhook global busca por findByIdOrdenPago().');",
                  "    console.log('Usá callback-pago-aprobado que busca por nroTramite.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-PlusPagos-Signature",
