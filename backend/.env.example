# ============================================================
# SISTEMA RDAM — Variables de entorno para desarrollo local
#
# CÓMO USAR:
#   Desde la RAÍZ del proyecto, ejecutá:
#   docker compose --env-file ./backend/.env up --build
#
# URLS disponibles una vez levantado:
#   http://localhost        → Portal ciudadano / portal interno (nginx)
#   http://localhost/api/v1 → API Spring Boot (vía nginx proxy)
#   http://localhost:8080   → API Spring Boot (acceso directo / Postman)
#   http://localhost:8025   → MailHog UI (ver emails capturados localmente)
#   http://localhost:9001   → MinIO Console (gestor de archivos)
#   http://localhost:3000   → PlusPagos Mock (simulador de pagos)
#
# FRONTEND en modo dev (sin Docker):
#   cd frontend && npm install && npm run dev
#   → corre en http://localhost:5173
#   → el proxy de Vite reenvía /api/* a http://localhost:8080 automáticamente
#
# NUNCA subir este archivo al repositorio.
# ============================================================


# ------------------------------------------------------------
# BASE DE DATOS — MySQL 8
# ------------------------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/rdam_db?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=America/Argentina/Buenos_Aires&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=rdam_user
DB_PASSWORD=rdam_pass_local


# ------------------------------------------------------------
# REDIS — Tokens OTP efímeros
# Sin contraseña en desarrollo local.
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# ------------------------------------------------------------
# MINIO — Almacenamiento de certificados PDF
# Credenciales solo válidas para desarrollo local.
# ------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=rdam-certificados


# ------------------------------------------------------------
# SMTP — Gmail (smtp.gmail.com:587 con STARTTLS)
#
# SMTP_USERNAME → tu dirección de Gmail (ej: sistema.rdam@gmail.com)
# SMTP_PASSWORD → Contraseña de Aplicación de Google (NO tu contraseña normal)
#   Para generarla: Cuenta de Google → Seguridad → Verificación en 2 pasos
#   → Contraseñas de aplicaciones → Generar (16 caracteres, sin espacios)
# MAIL_FROM     → debe ser igual a SMTP_USERNAME para que Gmail lo acepte
#
# NOTA: host (smtp.gmail.com), port (587), auth y starttls están
# hardcodeados en application.properties. Solo necesitás completar
# las credenciales acá.
# ------------------------------------------------------------
SMTP_USERNAME=TU_CUENTA@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=TU_CUENTA@gmail.com


# ------------------------------------------------------------
# JWT
# Mínimo 32 caracteres para HMAC-SHA256.
# Solo para desarrollo — no usar en producción.
# ------------------------------------------------------------
JWT_SECRET=desarrollo-local-2026-este-secret-es-solo-para-dev


# ------------------------------------------------------------
# PAGOS — Modo simulación (sin cobros reales)
# ------------------------------------------------------------
PAYMENT_MODE=sim
PLUSPAGOS_HMAC_SECRET=clave-secreta-campus-2026
PLUSPAGOS_MERCHANT_GUID=test-merchant-001
PLUSPAGOS_SECRET_KEY=clave-secreta-campus-2026
# URL interna — Spring Boot usa esta para hablar con el mock dentro de la red Docker
PLUSPAGOS_API_URL=http://pluspagos-mock:3000
# URL pública — la que ve el ciudadano al ser redirigido al formulario de pago
PLUSPAGOS_PUBLIC_URL=http://localhost:3000
SIM_AUTO_APPROVE=false


# ------------------------------------------------------------
# REGLAS DE NEGOCIO — Valores reducidos para dev
# Días pequeños para poder probar vencimientos sin esperar días reales.
# ------------------------------------------------------------
MONTO_ARANCEL=1500.00
VENCIMIENTO_PENDIENTE_DIAS=1
VALIDEZ_CERTIFICADO_DIAS=2


# ------------------------------------------------------------
# URL BASE — Para construir links internos (callbacks) y públicos (emails)
#
# Windows / Mac corriendo con Docker:
# ------------------------------------------------------------
SERVER_BASE_URL=http://host.docker.internal:8080
SERVER_PUBLIC_URL=http://localhost:8080

# Linux: descomentá estas dos y comentá las de arriba
# SERVER_BASE_URL=http://172.17.0.1:8080
# SERVER_PUBLIC_URL=http://localhost:8080