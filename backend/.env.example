# ============================================
# SISTEMA RDAM — Variables de entorno locales
# NUNCA subir este archivo al repositorio.
# Copiá .env.example y completá los valores.
# ============================================


# --------------------------------------------
# BASE DE DATOS
# --------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/rdam_db?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=America/Argentina/Buenos_Aires&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=rdam_user
DB_PASSWORD=rdam_pass_local


# --------------------------------------------
# REDIS
# Sin contraseña en desarrollo local.
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# --------------------------------------------
# MINIO
# Estas credenciales son solo para desarrollo.
# --------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=rdam-certificados


# --------------------------------------------
# SMTP — Mailhog (captura emails localmente)
# --------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_AUTH=false
SMTP_STARTTLS=false
SMTP_USERNAME=rdam.dev@gmail.com
SMTP_PASSWORD=
MAIL_FROM=rdam.dev@gmail.com


# --------------------------------------------
# JWT
# Mínimo 32 caracteres para HMAC-SHA256.
# Generá uno seguro con: openssl rand -hex 32
# --------------------------------------------
JWT_SECRET=desarrollo-local-2026-este-secret-es-solo-para-dev


# --------------------------------------------
# PAGOS — Modo simulación
# --------------------------------------------
PAYMENT_MODE=sim
PLUSPAGOS_HMAC_SECRET=clave-secreta-campus-2026
PLUSPAGOS_MERCHANT_GUID=test-merchant-001
PLUSPAGOS_SECRET_KEY=clave-secreta-campus-2026
# URL interna — Spring Boot usa esta para llamar al mock desde dentro de Docker
PLUSPAGOS_API_URL=http://pluspagos-mock:3000
# URL pública — la que se le muestra al ciudadano para abrir en el navegador
PLUSPAGOS_PUBLIC_URL=http://localhost:3000
SIM_AUTO_APPROVE=false


# --------------------------------------------
# REGLAS DE NEGOCIO — Valores para DEV
# Días reducidos para poder probar vencimientos
# sin esperar días reales.
# --------------------------------------------
MONTO_ARANCEL=1500.00
VENCIMIENTO_PENDIENTE_DIAS=1
VALIDEZ_CERTIFICADO_DIAS=2


# --------------------------------------------
# URL BASE — Para construir links internos (callbacks) y públicos (emails)
# FIX: SERVER_PUBLIC_URL faltaba en este archivo.
# Cuando el backend corre fuera de Docker (ej: ./mvnw spring-boot:run),
# application.properties lo necesita para construir el link de descarga en emails.
# --------------------------------------------
# Windows/Mac corriendo backend en Docker:
SERVER_BASE_URL=http://host.docker.internal:8080
SERVER_PUBLIC_URL=http://localhost:8080

# Linux: descomentá estas dos y comentá las de arriba
# SERVER_BASE_URL=http://172.17.0.1:8080
# SERVER_PUBLIC_URL=http://localhost:8080